{
  "info": {
    "_postman_id": "bulk-user-mgmt-v1",
    "name": "Bulk User Management API",
    "description": "Complete API collection for the Bulk User Management System.\n\nBase URL: http://localhost:5000\n\nFeatures:\n- Bulk create 5,000–10,000+ users\n- Bulk update with flexible filters\n- Paginated listing with search\n- Export as JSON or BSON\n- Stats & aggregations",

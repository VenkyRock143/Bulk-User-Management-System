    {
      "name": "🏥 Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "API Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
          }
        }
      ]
    },

    {
      "name": "👤 Single User CRUD",
      "item": [
        {
          "name": "Create Single User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data._id) {",
                  "  pm.collectionVariables.set('userId', json.data._id);",
                  "  console.log('Saved userId:', json.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Venkatesh\",\n  \"lastName\": \"Reddy\",\n  \"email\": \"venkatesh.reddy@example.com\",\n  \"username\": \"venkatesh_reddy\",\n  \"password\": \"Secure@123\",\n  \"phone\": \"+91-9876543210\",\n  \"role\": \"manager\",\n  \"status\": \"active\",\n  \"department\": \"Engineering\",\n  \"jobTitle\": \"Tech Lead\",\n  \"age\": 28,\n  \"gender\": \"male\",\n  \"address\": {\n    \"street\": \"42 Banjara Hills\",\n    \"city\": \"Hyderabad\",\n    \"state\": \"Telangana\",\n    \"zip\": \"500034\",\n    \"country\": \"India\"\n  },\n  \"tags\": [\"backend\", \"nodejs\"],\n  \"isVerified\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "users", "{{userId}}"] }
          }
        },
        {
          "name": "Update Single User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobTitle\": \"Senior Tech Lead\",\n  \"department\": \"Platform Engineering\",\n  \"tags\": [\"backend\", \"nodejs\", \"mongodb\"],\n  \"isVerified\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "users", "{{userId}}"] }
          }
        },
        {
          "name": "Delete Single User (Soft)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "users", "{{userId}}"] }
          }
        }
      ]
    },

    {
      "name": "📋 List & Search Users",
      "item": [
        {
          "name": "List All Users (default)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users?page=1&limit=20",
              "host": ["{{baseUrl}}"], "path": ["api", "users"],
